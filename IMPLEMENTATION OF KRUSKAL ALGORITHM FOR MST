#include <stdio.h>
#include <stdlib.h>

#define NODES 5
#define EDGES 6

struct Link {
    int a, b, cost;
};

int parent[NODES];

int root(int x) {
    if (parent[x] == x)
        return x;
    return root(parent[x]);
}

void merge(int x, int y) {
    int rx = root(x);
    int ry = root(y);
    parent[rx] = ry;
}

int cmp(const void *p, const void *q) {
    return ((struct Link *)p)->cost - ((struct Link *)q)->cost;
}

void buildMST(struct Link arr[]) {
    printf("\nMinimum Spanning Tree:\n");
    printf("Edge \tCost\n");

    qsort(arr, EDGES, sizeof(arr[0]), cmp);

    for (int i = 0; i < NODES; i++)
        parent[i] = i;

    int edgesUsed = 0;
    int sum = 0;

    for (int i = 0; i < EDGES && edgesUsed < NODES - 1; i++) {
        int u = arr[i].a;
        int v = arr[i].b;

        if (root(u) != root(v)) {
            printf("%d - %d \t%d\n", u, v, arr[i].cost);
            sum += arr[i].cost;
            merge(u, v);
            edgesUsed++;
    }
    }

    printf("Total Cost = %d\n", sum);
}

int main() {
    struct Link graph[EDGES] = {
        {0, 1, 2},
        {0, 2, 3},
        {1, 2, 5},
        {1, 3, 3},
        {2, 4, 4},
        {3, 4, 2}
    };

    buildMST(graph);
    return 0;
}
